四、五大功能模块详细规格
4.1 排名模块 (ranking)
4.1.1 模块说明
用于处理商品销售排名数据，从抖店后台导出的销售数据Excel中读取数据。

4.1.2 数据处理规则
显示在页面上的处理规则说明：

📊 排名数据处理规则:
• 商品名称: 保留「字符及其后内容
• 讲解次数: 转数值，无效值记0
• 成交金额: 来自"用户支付金额"列，去除¥和,后转数值
• 点击率: 去%后除以100转小数
• 过滤条件: 用户支付金额<100元的记录将被过滤
4.1.3 源文件字段与处理逻辑
源Excel列索引	源字段名	目标数据库字段	处理逻辑
1	商品名称	productName	extractShortName(value) - 保留「字符及其后内容
2	讲解次数	lectureCount	parseNumber(value) - 转整数，无效记0
6	用户支付金额	salesAmount	parseAmount(value) - 去除¥和逗号转数值，这个值写入成交金额字段
9	曝光点击率	exposureRate	parsePercentage(value) - 去%除以100
10	点击成交率	conversionRate	parsePercentage(value) - 去%除以100
过滤规则：用户支付金额 < 100 的记录不导入

4.1.4 处理函数实现
// lib/processors/ranking.ts
interface RankingRecord {
  productName: string;
  lectureCount: number;
  salesAmount: number;
  exposureRate: number;
  conversionRate: number;
}
/**
 * 提取商品简称 - 保留「字符及其后的内容
 * 例如: "【店铺】商品A「简称B」" -> "「简称B」"
 */
function extractShortName(fullName: string): string {
  if (!fullName) return '';
  const trimmed = fullName.trim();
  if (trimmed.includes('「')) {
    const parts = trimmed.split('「');
    if (parts.length > 1) {
      return '「' + parts[parts.length - 1];
    }
  }
  return trimmed;
}
/**
 * 解析数值 - 处理各种格式的数值字符串
 */
function parseNumber(value: unknown): number {
  if (value === null || value === undefined) return 0;
  if (typeof value === 'number') {
    return isFinite(value) ? value : 0;
  }
  const str = String(value).trim();
  if (!str || str.toLowerCase() === 'nan' || str.toLowerCase() === 'none') {
    return 0;
  }
  // 移除非数字字符（保留小数点和负号）
  const cleaned = str.replace(/[^\d.\-]/g, '');
  const num = parseFloat(cleaned);
  return isFinite(num) ? num : 0;
}
/**
 * 解析金额 - 去除¥符号和逗号
 */
function parseAmount(value: unknown): number {
  if (value === null || value === undefined) return 0;
  const str = String(value).trim();
  const cleaned = str.replace(/[¥￥,，]/g, '');
  return parseNumber(cleaned);
}
/**
 * 解析百分比 - 去除%并转换为小数
 * 例如: "5.3%" -> 0.053
 */
function parsePercentage(value: unknown): number {
  if (value === null || value === undefined) return 0;
  const str = String(value).trim();
  if (str.includes('%')) {
    const cleaned = str.replace('%', '');
    const num = parseNumber(cleaned);
    return num / 100;
  }
  return parseNumber(value);
}
/**
 * 处理排名数据
 * @param rows - Excel解析后的二维数组，第一行为表头
 */
export function processRankingData(rows: unknown[][]): RankingRecord[] {
  const records: RankingRecord[] = [];
  
  // 跳过表头，从第2行开始处理
  for (let i = 1; i < rows.length; i++) {
    const row = rows[i];
    if (!row || row.length === 0) continue;
    
    // 获取商品名称
    const rawProductName = String(row[1] ?? '').trim();
    if (!rawProductName || rawProductName === 'nan') continue;
    
    // 提取商品简称
    const productName = extractShortName(rawProductName);
    
    // 获取用户支付金额（列索引6）用于过滤和写入
    const userPayment = parseAmount(row[6]);
    
    // 过滤条件：用户支付金额 < 100 的记录不导入
    if (userPayment < 100) continue;
    
    const record: RankingRecord = {
      productName,
      lectureCount: Math.round(parseNumber(row[2])),
      salesAmount: userPayment,  // 用户支付金额写入成交金额字段
      exposureRate: parsePercentage(row[9]),
      conversionRate: parsePercentage(row[10]),
    };
    
    records.push(record);
  }
  
  return records;
}
