4.4.4 样品序号生成算法（核心业务逻辑）
/**
 * 样品序号生成规则：
 * 1. 按商品编码排序
 * 2. 按商品名称（初始名称）去重，只保留首次出现的
 * 3. 过滤掉商品标签包含"福利"的商品（不分配序号）
 * 4. 前20个商品: A01, A03, A05, A07, ..., A39（奇数编号）
 * 5. 第21个商品开始: A41, A42, A43, ...（连续编号）
 */
function generateSampleNumbers(records: NewProductRecord[]): Map<string, string> {
  // 1. 按商品编码排序
  const sorted = [...records].sort((a, b) => 
    (a.productCode ?? '').localeCompare(b.productCode ?? '')
  );
  
  // 2. 按初始名称去重
  const seenNames = new Set<string>();
  const unique: NewProductRecord[] = [];
  for (const record of sorted) {
    const name = record.initialName;
    if (!seenNames.has(name)) {
      seenNames.add(name);
      unique.push(record);
    }
  }
  
  // 3. 过滤掉商品标签包含"福利"的
  const filtered = unique.filter(r => {
    const tag = r.productTag ?? '';
    return !tag.includes('福利');
  });
  
  // 4. 分配序号
  const mapping = new Map<string, string>();
  filtered.forEach((record, index) => {
    let sampleNumber: string;
    if (index < 20) {
      // 前20个: 奇数序号 A01, A03, A05, ..., A39
      const num = index * 2 + 1;
      sampleNumber = `A${num.toString().padStart(2, '0')}`;
    } else {
      // 第21个开始: A41, A42, A43, ...
      const num = index + 21;
      sampleNumber = `A${num.toString().padStart(2, '0')}`;
    }
    mapping.set(record.initialName, sampleNumber);
  });
  
  return mapping;
}
