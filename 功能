4.3 ID模块 (product-id)
4.3.1 模块说明
用于处理商品ID数据，支持Excel和CSV两种格式。

4.3.2 数据处理规则
🆔 ID数据处理规则:
• 支持Excel和CSV格式
• CSV需包含'商品名称'和'商品ID'表头
• 商品名称保留「后部分
• 商品ID去除'ID:'前缀
• 按商品名称去重，直接上传不清空
4.3.3 源文件字段与处理逻辑
源字段/列索引	目标数据库字段	处理逻辑
商品名称 (列1)	productName	extractShortName(value) + 按此字段去重，只保留首条
商品ID (列0)	productId	去除 ID: 前缀
商品价格 (列13)	productPrice	转数值（仅Excel有）
三级分类 (列4)	storeCategory	原样保留（仅Excel有）
4.3.4 处理函数实现
// lib/processors/productId.ts
interface ProductIdRecord {
  productName: string;
  productId: string;
  productPrice?: number;
  storeCategory?: string;
}
/**
 * 处理ID数据 - 按商品名称去重
 */
export function processProductIdData(rows: unknown[][]): ProductIdRecord[] {
  const seenProducts = new Set<string>();
  const records: ProductIdRecord[] = [];
  
  // 跳过表头
  for (let i = 1; i < rows.length; i++) {
    const row = rows[i];
    if (!row || row.length === 0) continue;
    
    // 获取并处理商品名称
    const rawProductName = String(row[1] ?? '').trim();
    if (!rawProductName || rawProductName === 'nan') continue;
    
    const productName = extractShortName(rawProductName);
    
    // 去重：按商品名称去重，仅保留首条
    if (seenProducts.has(productName)) continue;
    seenProducts.add(productName);
    
    // 处理商品ID：去除 'ID:' 前缀
    let productId = String(row[0] ?? '').trim();
    if (productId.startsWith('ID:')) {
      productId = productId.substring(3).trim();
    }
    
    const record: ProductIdRecord = {
      productName,
      productId,
    };
    
    // 商品价格（仅Excel，列索引13）
    if (row.length > 13) {
      record.productPrice = parseNumber(row[13]);
    }
    
    // 三级分类（仅Excel，列索引4）
    if (row.length > 4) {
      const category = String(row[4] ?? '').trim();
      if (category && category !== 'nan') {
        record.storeCategory = category;
      }
    }
    
    records.push(record);
  }
  
  return records;
}
