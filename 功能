// lib/processors/newProduct.ts
interface NewProductRecord {
  initialName: string;
  imageUrl: string;
  virtualCategory: string;
  productCode: string;
  category: string;
  colorSpec: string;
  basePrice: number;
  warehouse: string;
  productTag: string;
  sampleNumber: string;
}
export function processNewProductData(rows: unknown[][]): NewProductRecord[] {
  // 第一遍：收集所有记录
  const tempRecords: NewProductRecord[] = [];
  
  for (let i = 1; i < rows.length; i++) {
    const row = rows[i];
    if (!row || row.length === 0) continue;
    
    const productName = String(row[1] ?? '').trim();
    if (!productName || productName === 'nan') {
      console.warn('警告: 跳过空的商品名称行');
      continue;
    }
    
    tempRecords.push({
      initialName: productName,
      imageUrl: String(row[0] ?? ''),
      virtualCategory: String(row[3] ?? ''),
      productCode: String(row[2] ?? ''),
      category: String(row[4] ?? ''),
      colorSpec: String(row[6] ?? ''),
      basePrice: parseNumber(row[15]),
      warehouse: String(row[7] ?? ''),
      productTag: String(row[16] ?? ''),
      sampleNumber: '', // 稍后填充
    });
  }
  
  // 生成样品序号映射
  const sampleMapping = generateSampleNumbers(tempRecords);
  
  // 第二遍：填充样品序号
  const records: NewProductRecord[] = [];
  for (const record of tempRecords) {
    const productTag = record.productTag;
    
    // 如果商品标签包含"福利"，则不分配样品序号
    if (productTag.includes('福利')) {
      record.sampleNumber = '';
    } else {
      record.sampleNumber = sampleMapping.get(record.initialName) ?? '';
    }
    
    records.push(record);
  }
  
  return records;
}
