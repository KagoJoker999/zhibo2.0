// lib/processors/coupon.ts
interface CouponRecord {
  inputProductCode: string;
  imageUrl: string;
}
/**
 * 查找商品名称列的索引
 */
function findProductNameColumn(headers: string[]): number {
  const aliases = ['商品名称', '商品', '名称', '产品名称', '产品'];
  
  for (const alias of aliases) {
    const index = headers.findIndex(h => 
      h && h.toString().includes(alias)
    );
    if (index !== -1) return index;
  }
  
  // 默认返回列索引1
  return 1;
}
export function processCouponData(rows: unknown[][]): CouponRecord[] {
  const records: CouponRecord[] = [];
  
  // 获取表头
  const headers = (rows[0] ?? []).map(h => String(h ?? ''));
  
  // 智能查找商品名称列
  const productNameCol = findProductNameColumn(headers);
  const imageCol = 0; // 图片固定在A列
  
  // 跳过表头
  for (let i = 1; i < rows.length; i++) {
    const row = rows[i];
    if (!row || row.every(cell => cell === null || cell === undefined)) continue;
    
    const productName = String(row[productNameCol] ?? '').trim();
    if (!productName || productName === 'nan') continue;
    
    const imageUrl = String(row[imageCol] ?? '').trim();
    
    records.push({
      inputProductCode: productName,
      imageUrl: imageUrl !== 'nan' ? imageUrl : '',
    });
  }
  
  return records;
}
