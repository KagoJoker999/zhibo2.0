三、数据库设计
3.1 Prisma Schema 定义
// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
// 排名数据表 - 存储商品销售排名数据
model RankingData {
  id              Int       @id @default(autoincrement())
  productName     String    @map("product_name")        // 商品名称
  lectureCount    Int       @default(0) @map("lecture_count")    // 讲解次数
  salesAmount     Float     @default(0) @map("sales_amount")     // 成交金额（用户支付金额）
  exposureRate    Float     @default(0) @map("exposure_rate")    // 曝光点击率（小数形式，如0.053表示5.3%）
  conversionRate  Float     @default(0) @map("conversion_rate")  // 点击成交率（小数形式）
  deleteMarker    String?   @map("delete_marker")       // 删除标记（"待删除"表示可删除）
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  @@map("ranking_data")
}
// 库存数据表 - 存储商品库存信息
model InventoryData {
  id              Int       @id @default(autoincrement())
  productName     String    @map("product_name")        // 商品名称（合并key）
  imageUrl        String?   @map("image_url")           // 图片地址
  productTag      String?   @map("product_tag")         // 商品标签（逗号分隔，去重合并）
  virtualCategory String?   @map("virtual_category")    // 虚拟分类（逗号分隔，去重合并）
  productCode     String?   @map("product_code")        // 商品编码（逗号分隔，去重合并）
  warehouse       String?   @map("warehouse")           // 仓位（逗号分隔，去重合并）
  availableQty    Int       @default(0) @map("available_qty")    // 可用数（相加）
  actualStock     Int       @default(0) @map("actual_stock")     // 实际库存数（相加）
  productCategory String?   @map("product_category")    // 商品分类（逗号分隔，去重合并）
  deleteMarker    String?   @map("delete_marker")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  @@map("inventory_data")
}
// ID数据表 - 存储商品ID信息
model ProductIdData {
  id              Int       @id @default(autoincrement())
  productName     String    @map("product_name")        // 商品名称（去重key）
  productId       String?   @map("product_id")          // 商品ID
  productPrice    Float     @default(0) @map("product_price")    // 商品价格
  storeCategory   String?   @map("store_category")      // 抖店分类
