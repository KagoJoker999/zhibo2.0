4.2 库存模块 (inventory)
4.2.1 模块说明
用于处理商品库存数据，核心特点是同名商品自动合并。

4.2.2 数据处理规则
📦 库存数据处理规则:
• 同名商品自动合并
• 数值字段(可用数/库存数): 相加
• 文本字段(标签/分类等): 去重合并
• 字段映射: 图片→图片地址, 主仓位→仓位
4.2.3 源文件字段与处理逻辑
源Excel列索引	源字段名	目标数据库字段	处理逻辑
1	商品名称	productName	作为合并key
0	图片	imageUrl	取第一个非空值
1	商品标签	productTag	去重后用逗号合并
3	虚拟分类	virtualCategory	去重后用逗号合并
8	商品编码	productCode	去重后用逗号合并
9	主仓位	warehouse	去重后用逗号合并
10	可用数	availableQty	数值相加
10	实际库存数	actualStock	数值相加
28	分类	productCategory	去重后用逗号合并
4.2.4 处理函数实现
// lib/processors/inventory.ts
interface InventoryRecord {
  productName: string;
  imageUrl: string;
  productTag: string;
  virtualCategory: string;
  productCode: string;
  warehouse: string;
  availableQty: number;
  actualStock: number;
  productCategory: string;
}
/**
 * 处理库存数据 - 核心是同名商品合并
 */
export function processInventoryData(rows: unknown[][]): InventoryRecord[] {
  // 用于存储按商品名称分组的数据
  const productMap = new Map<string, {
    imageUrl: string;
    productTag: Set<string>;
    virtualCategory: Set<string>;
    productCode: Set<string>;
    warehouse: Set<string>;
    availableQty: number;
    actualStock: number;
    productCategory: Set<string>;
  }>();
  
  // 跳过表头
  for (let i = 1; i < rows.length; i++) {
    const row = rows[i];
    if (!row || row.length === 0) continue;
    
    const productName = String(row[1] ?? '').trim();
    if (!productName || productName === 'nan') continue;
    
    // 获取或创建该商品的数据对象
    if (!productMap.has(productName)) {
      productMap.set(productName, {
        imageUrl: '',
        productTag: new Set(),
        virtualCategory: new Set(),
        productCode: new Set(),
        warehouse: new Set(),
        availableQty: 0,
        actualStock: 0,
        productCategory: new Set(),
      });
    }
    
    const data = productMap.get(productName)!;
    
    // 图片地址：只取第一个非空值
    if (!data.imageUrl) {
      const img = String(row[0] ?? '').trim();
      if (img && img !== 'nan') data.imageUrl = img;
    }
    
    // 文本字段：去重合并（添加到Set）
    const addToSet = (set: Set<string>, value: unknown) => {
      const str = String(value ?? '').trim();
      if (str && str !== 'nan') set.add(str);
    };
    
    addToSet(data.productTag, row[1]);
    addToSet(data.virtualCategory, row[3]);
    addToSet(data.productCode, row[8]);
    addToSet(data.warehouse, row[9]);
    addToSet(data.productCategory, row[28]);
    
    // 数值字段：相加
    data.availableQty += parseNumber(row[10]);
    data.actualStock += parseNumber(row[10]);
  }
  
  // 转换为最终记录格式
  const records: InventoryRecord[] = [];
  productMap.forEach((data, productName) => {
    records.push({
      productName,
      imageUrl: data.imageUrl,
      productTag: Array.from(data.productTag).filter(Boolean).join(','),
      virtualCategory: Array.from(data.virtualCategory).filter(Boolean).join(','),
      productCode: Array.from(data.productCode).filter(Boolean).join(','),
      warehouse: Array.from(data.warehouse).filter(Boolean).join(','),
      availableQty: Math.round(data.availableQty),
      actualStock: Math.round(data.actualStock),
      productCategory: Array.from(data.productCategory).filter(Boolean).join(','),
    });
  });
  
  return records;
}
