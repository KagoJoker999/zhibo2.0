### 8.3 核心算法移植

筛选引擎核心逻辑（JavaScript/TypeScript 版本）：

```typescript
class ProductFilter {
  private config: FilterConfig;
  private usedProducts: Set<string> = new Set();
  
  filterProducts(products: Product[]): Record<string, Product[]> {
    const results: Record<string, Product[]> = {};
    
    for (const category of this.config.分类排序) {
      const conditions = this.config.筛选条件[category];
      let available = products.filter(p => !this.usedProducts.has(p.商品名称));
      
      if (category === "库存品筛选条件") {
        available = this.filterInventoryProducts(available, conditions);
      } else if (conditions.按子分类分别筛选) {
        available = this.filterBySubcategory(available, conditions);
      } else {
        available = this.applyFilters(available, conditions);
      }
      
      available.forEach(p => this.usedProducts.add(p.商品名称));
      results[category] = available;
    }
    
    return results;
  }
  
  // ... 其余方法实现
}
```

