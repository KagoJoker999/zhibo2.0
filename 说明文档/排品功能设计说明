### 4.2 筛选配置结构

```typescript
interface FilterConfig {
  分类排序: string[];          // 筛选顺序，如 ["评分品A筛选条件", "佩戴品筛选条件", ...]
  结果映射: Record<string, string>;  // 分类名 -> 结果标签，如 {"评分品A筛选条件": "1.评分品A"}
  筛选条件: Record<string, CategoryCondition>;
}

interface CategoryCondition {
  [fieldName: string]: FieldCondition;
  按子分类分别筛选?: boolean;  // 是否按子分类分别筛选
  子分类字段?: string;         // 子分类字段名
}

interface FieldCondition {
  启用: boolean;
  大于等于?: number;
  小于等于?: number;
  等于?: string | string[];
  包含?: string | string[];
  排除?: string | string[];
  前几名?: number;
  后几名?: number;
}
```

